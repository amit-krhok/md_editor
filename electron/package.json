{
  "name": "electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.14.0"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1",
    "electron": "^41.1.0"
  },
  "build": {
    "appId": "com.mdeditor.app",
    "productName": "MD Editor",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "_security_note_baked_env": "SECURITY: Personal use only. Baking electron/.env into the DMG exposes secrets—unsafe for public distribution.",
    "files": [
      "**/*",
      "!packaged.env.example"
    ],
    "extraResources": [
      {
        "from": "../docker-compose.electron.yml",
        "to": "."
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.venv",
          "!**/.venv/**",
          "!**/.pytest_cache/**"
        ]
      },
      {
        "from": "../ui",
        "to": "ui",
        "filter": [
          "**/*",
          "!**/node_modules",
          "!**/node_modules/**",
          "!**/.next",
          "!**/.next/**"
        ]
      },
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "packaged.env.example",
        "to": "packaged.env.example"
      }
    ]
  }
}
