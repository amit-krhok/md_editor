POSTGRES_USER=md_editor
POSTGRES_PASSWORD=md_editor
POSTGRES_DB=md_editor

# FastAPI (async via asyncpg) and Alembic (sync via psycopg2). Use postgresql:// — the app rewrites to asyncpg.
DATABASE_URL=postgresql://md_editor:md_editor@localhost:5432/md_editor

# JWT signing (use a long random secret in production)
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated emails that register as active immediately (trimmed, case-insensitive)
# SUPERUSER_EMAILS=you@example.com,other@example.com

# Directory for rotating app.log (default: backend/logs). Docker Compose sets /app/logs.
# LOG_DIR=/path/to/logs

# Browser origins allowed to call the API (production). If unset, dev allows localhost / 127.0.0.1 / [::1] on any port.
# CORS_ORIGINS=https://your-app.example.com

# UI Docker build: API base URL as seen from the browser.
# With nginx (default compose): same origin + /api prefix → http://localhost/api
# Direct API (no nginx path): http://localhost:8005
# NEXT_PUBLIC_API_URL=http://localhost/api

# Host path mounted as /etc/md_editor/certs for optional HTTPS (fullchain.pem + privatekey.pem).
# MD_EDITOR_CERT_DIR=./certs
