POSTGRES_USER=md_editor
POSTGRES_PASSWORD=md_editor
POSTGRES_DB=md_editor

# FastAPI / Alembic on the host (localhost). Overridden in docker-compose for the api service.
DATABASE_URL=postgresql://md_editor:md_editor@localhost:5432/md_editor

# JWT signing (use a long random secret in production)
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated emails that register as active immediately (trimmed, case-insensitive)
# SUPERUSER_EMAILS=you@example.com,other@example.com
